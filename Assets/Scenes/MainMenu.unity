  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "- Player has a color cycle, with each color giving a different \nstatistic
    multiplier; use [LEFT CTRL] to cycle colors.\n\n- Colors:\n- Red: Attack Multiplier\n-
    Blue: Defense Multiplier\n- Green: Regeneration Multiplier\n\n- Each time the
    player steps on a platform with no enemies on it, the platform \nwill be claimed
    with the player's current color.\r\n\n- Color multiplier will increase depending
    on how many platforms of that color the player has \nclaimed.\r\n\n- To actually
    gain the multiplier of a color, the player must be cycled to that color.\r\n\n-
    Phantoms cannot spawn on platforms claimed by player.\r\n\n- Player loses all
    claims on death.\r\n\n- Use [A] & [D] to move left and right respectively, [SPACE]
    to jump, [LEFT CLICK] to shoot, \n[R] to reload.\r\n\n- Player starts with specific
    starter guns, depending on the level, use [SCROLL WHEEL] to cycle \nthrough them.\r\n\n-
    Enemies are called phantoms, there are various types:\n- Basic Phantom\n- Hyper
    Phantom\n- Radiant Phantom\n- Nova Phantom\n- Stellar Phantom\n- Quantum Phantom\n-
    Quantum Elite Phantom\n- Void Phantom\n- Galactic Phantom\n\n- Phantoms will
    react quicker if player is seen in frontal vision, will react \nslower if player
    sneaks up behind.\n\n- Objective is to eliminate all phantoms & claim all platforms.\n\nHidden
    Mechanics:\n- Jumping: Holding down jump will allow you to jump higher than normal.\n-
    Mantling: Jump into the side of a platform to gain a second jump."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 9c9b109dd5f37854b9e80c2907833682, type: 2}
  m_sharedMaterial: {fileID: -3818769081518171636, guid: 9c9b109dd5f37854b9e80c2907833682, type: 2}
